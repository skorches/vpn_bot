PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vpn_service_dev?schema=public

# Example: https://194.87.25.58:14365
XUI_PANEL_ORIGIN=

# Example: GKPaDRvyFpnzqBp25d
XUI_WEB_BASE_PATH=

XUI_USERNAME=
XUI_PASSWORD=

# Optional: use exact inbound as anti profile template
XUI_ANTI_TEMPLATE_INBOUND_ID=

# Optional: host used in generated client URI (defaults to host from XUI_PANEL_ORIGIN)
XUI_PUBLIC_HOST=

# Optional: inbound id used for instant Telegram provisioning
XUI_DEFAULT_INBOUND_ID=

# Telegram bot integration
TELEGRAM_POLL_INTERVAL_MS=2000
TELEGRAM_POLL_TIMEOUT_SECONDS=20
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_SUPPORT_LINK=
